# ============================================================
#  $KYRT — Kerythos AI · configuração de ambiente
#  Copie para `.env` e ajuste. NUNCA committe o .env real.
# ============================================================

# Cluster alvo: devnet | testnet | mainnet-beta | localnet
SOLANA_CLUSTER=devnet

# RPC customizado (opcional). Se vazio, usa o RPC público do cluster.
# Em produção, use um RPC dedicado (Helius, Triton, QuickNode...).
SOLANA_RPC_URL=

# Keypair da treasury/deployer. Se o arquivo não existir, é gerado
# automaticamente no primeiro comando. Mantenha-o FORA do git (.keys/).
TREASURY_KEYPAIR_PATH=.keys/treasury.json

# Endereço do mint do KYRT. Preenchido automaticamente por `npm run create`.
KYRT_MINT_ADDRESS=

# URI do JSON de metadados off-chain (nome, símbolo, imagem...).
# Em produção, hospede em Arweave/IPFS e cole a URL aqui.
KYRT_METADATA_URI=

# ============================================================
#  $KYRT — Kerythos AI · environment configuration
#  Copy to `.env` and adjust. NEVER commit the real .env.
# ============================================================

# Target cluster: devnet | testnet | mainnet-beta | localnet
SOLANA_CLUSTER=devnet

# Custom RPC (optional). If empty, uses the cluster's public RPC.
# In production, use a dedicated RPC (Helius, Triton, QuickNode...).
SOLANA_RPC_URL=

# Treasury/deployer keypair. If the file doesn't exist, it's generated
# automatically on the first command. Keep it OUT of git (.keys/).
TREASURY_KEYPAIR_PATH=.keys/treasury.json

# KYRT mint address. Filled in automatically by `npm run create`.
KYRT_MINT_ADDRESS=

# URI of the off-chain metadata JSON (name, symbol, image...).
# In production, host it on Arweave/IPFS and paste the URL here.
KYRT_METADATA_URI=

# --- Genesis distribution (`npm run distribute`) ---
# Wallets that receive the supply BEFORE the mint authority is revoked.
# Required on mainnet-beta; on devnet, leave empty to use ephemeral test
# addresses for a dry-run. The Rewards wallet should be a Squads multisig.
KYRT_LIQUIDITY_WALLET=
KYRT_REWARDS_WALLET=
# Rewards pool share (%). Liquidity gets the remaining (100 − this). Default 15.
KYRT_REWARDS_PCT=15
